{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist-worker",
    "rootDir": "./src",
    "noEmitOnError": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "isolatedModules": true,
    "noImplicitAny": true,
    "lib": ["es2022"],
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist-worker",
    "public"
  ]
}