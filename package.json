{
  "name": "passflares",
  "version": "1.0.3",
  "description": "A modern and secure password manager built on the Cloudflare Stack.",
  "main": "src/worker.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env=\"\"",
    "release": "git checkout production && git merge --ff-only main && git push origin production && git checkout main",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:audit": "npm audit --audit-level=moderate",
    "test:all": "npm run test:audit && vitest run && playwright test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260519.1",
    "@playwright/test": "^1.60.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "happy-dom": "^20.9.0",
    "http-server": "^14.1.1",
    "typescript": "^5.5.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.93.0"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0",
    "itty-router": "^4.0.12",
    "jsonwebtoken": "^9.0.2"
  }
}
