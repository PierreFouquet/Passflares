{
  "name": "passflares",
  "version": "1.1.3",
  "description": "A modern and secure password manager built on the Cloudflare Stack.",
  "main": "src/worker.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env=\"\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:audit": "npm audit --audit-level=moderate",
    "test:all": "npm run test:audit && vitest run && playwright test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@playwright/test": "^1.61.1",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.19.42",
    "happy-dom": "^20.11.0",
    "http-server": "^14.1.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "itty-router": "^4.2.2",
    "jsonwebtoken": "^9.0.2",
    "otpauth": "^9.5.1",
    "qrcode-svg": "^1.1.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260710.1": true
  }
